+def test_m12_p144_suborbits_match_expected():
+    b11 = perm_from_cycles(12, [[1, 4], [3, 10], [5, 11], [6, 12]])
+    b21 = perm_from_cycles(12, [[1, 8, 9], [2, 3, 4], [5, 12, 11], [6, 10, 7]])
+    gens = [b11, b21, inv(b11), inv(b21)]
