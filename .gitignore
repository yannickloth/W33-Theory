# Ignore problematic Windows reserved names
nul
NUL

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*.class

# LaTeX auxiliary files
*.aux
*.log
*.out
*.toc

# Temp files
tmpclaude-*
*.tmp
tmp*.log
run*.log
latex_build.log

# Multi-run local scratch directories (safe to ignore)
artifacts_for_release_*/
artifacts_run_*/
artifacts_try_*/
tmp_artifacts_*/
ChatGPT 5.2/
tmpclaude-*/
logs/

# Local artifacts & CI outputs
artifacts/
sage-part-jsons*
SUMMARY_RESULTS.json
NUMERIC_COMPARISONS.json
outputs/

# Generated output files from CI/CD and Sage verification
PART_*.json
# Allow PART_*.json files inside `committed_artifacts/` to be tracked so
# verification artifacts (e.g., PART_CVII_*.json) are visible to collaborators
!committed_artifacts/PART_*.json

# Extracted bundles (redundant with bundles/ directory)
extracted/

# Optional external dependencies
external/pysymmetry/
external/sage/

# Local virtual env
.venv/
.venv_wsl/
.venv_toe/
.venv_tools/
.venv_test/
.venv_codex/

# local workspace data
claude_workspace/data/
.mypy_cache/
.pytest_cache/

# Editor / OS files
.DS_Store
Thumbs.db
.claude/
# Local generated plots/artifacts
sp4_spectrum_test.png

# Local checks and temporary output (do NOT commit transient files)
checks/_tmp_*
checks/*_tmp_*.json
checks/*_verify_*.json
checks/*_seed_*.json
checks/z3_analysis_*/
checks/*.npz
checks/*.log
checks/pytest_run_latest.txt
# Archive for cleaned temporary outputs (keep for reproducibility but don't scan in CI)
checks/archive/

# Ignore editor settings and temporary workspace files
.vscode/

# Ignore large generated bundles for local experiments (keep repo lightweight)
bundles/v23_toe_finish/v23/
# But allow follow-up TDA outputs to be tracked
!bundles/v23_toe_finish/v23/gbs_threshold_tda_followup_*
!bundles/v23_toe_finish/v23/gbs_threshold_tda_followup_summary.*
# Allow correlation summaries and plots
!bundles/v23_toe_finish/v23/gbs_tda_correlation_summary.json
!bundles/v23_toe_finish/v23/gbs_tda_w_vs_js_correlation.png
# Allow walrus / tex parsing outputs
!bundles/v23_toe_finish/v23/walrus_sf_comparison.json
!bundles/v23_toe_finish/v23/tex_claims_summary.json

# Tools: track Python/Sage analysis scripts, ignore large runtimes
tools/__pycache__/
tools/gap/*.exe
tools/gap/*.tar.gz
tools/gap/*.zip

# Ignore locally created VSIX packages for extension development
tools/send-to-chatgpt-*.vsix

# Jupyter and transient process artifacts
.ipynb_checkpoints/
*.pid
*.err

# local backups
backups/

# Large zip bundles
*.zip
More New Work/
S12_NEXT_LEVEL_ASCII.py

# Local analysis bundle for W33 (generated by prepare_w33_analysis_bundle.py)
analysis/w33_bundle_temp/
